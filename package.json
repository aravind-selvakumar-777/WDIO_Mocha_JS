{
  "name": "WDIO_Mocha_JS",
  "type": "module",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.25.0",
    "@wdio/cli": "^9.24.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.2",
    "undici": "^6.23.0 || ^7.23.0",
    "yauzl": "^3.2.1"
  },
  "scripts": {
    "wdio": "wdio run ./wdio.conf.js",
    "report:generate": "npx allure generate allure-results --clean -o allure-report",
    "report:open": "npx allure open allure-report",
    "allure": "npm run report:generate && npm run report:open"
  }
}
